{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionString": "Host=localhost;Port=15432;Database=chatai;Username=postgres;Password=YOUR_PASSWORD",
  "EvolutionApi": {
    "ServerUrl": "https://server-url",
    "ApiKey": "API_KEY",
    "Instance": "INSTANCE"
  },
  "AIProvider": {
    "ApiKey": "API_KEY",
    "Endpoint": "https://api.openai.com/v1",
    "ChatModel": "gpt-5-nano",
    "ImageModel": "dall-e-3",
    "EmbedModel": "text-embedding-3-small",
    "TranscriptionModel": "whisper-1",
    "TtsModel": "tts-1",
    "TtsVoice": "alloy"
  },
  "Tools": {
    "midesp": {
      "Enabled": true,
      "Type": "stdio",
      "Command": "node",
      "WorkDir": "",
      "Args": [ "dist/index.js" ],
      "Envs": {
        "MIDESP_API_BASE_URL": "https://api.midesp.com.br"
      }
    },
    "midesp-sse": {
      "Enabled": false,
      "Type": "sse",
      "Endpoint": "http://localhost:5007",
      "Headers": {
        "ApiKey": "TOKEN"
      }
    }
  }
}
